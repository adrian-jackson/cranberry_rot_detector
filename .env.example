# .env.example
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# The .env file is never committed to git (it's in .gitignore).

# Your Modal inference endpoint.
# You get this URL after running `modal deploy modal_app.py`.
# It looks like: https://yourname--cranberry-inspector-predict.modal.run
MODAL_INFERENCE_URL=https://your-modal-url-here.modal.run
